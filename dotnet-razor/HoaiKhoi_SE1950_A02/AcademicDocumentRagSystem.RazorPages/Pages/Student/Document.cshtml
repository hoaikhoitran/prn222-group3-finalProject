@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Student.DocumentModel
@{
    ViewData["Title"] = Model.Document.Title;
    Layout = "_LayoutStudent";
    var doc = Model.Document;
    var chunk = Model.ActiveChunk;
    var statusClass = doc.IndexStatus == "Indexed" ? "status-badge-indexed" : "status-badge-processing";
}
<div class="d-flex flex-column" style="min-height:100vh;">
    <div class="border-bottom px-4 py-2 d-flex align-items-center gap-3 flex-wrap">
        <a asp-page="/Student/Library" class="btn btn-sm btn-edurag-ghost d-inline-flex align-items-center gap-1">
            @{ ViewData["Icon"] = "arrow-left"; ViewData["IconSize"] = "14"; }
            @await Html.PartialAsync("_Icons")
            Thư viện
        </a>
        <span class="@statusClass">@doc.IndexStatus</span>
        <span class="small text-muted-edurag">@doc.CourseCode@(doc.Chapter != null ? $" · {doc.Chapter}" : "")</span>
        <a asp-page="/Student/Chat" asp-route-documentId="@doc.DocumentId" class="btn btn-sm btn-edurag-warm ms-auto">Hỏi đáp RAG</a>
    </div>
    <div class="row g-0 flex-grow-1">
        <div class="col-lg-8 border-end p-4 overflow-auto bg-muted-edurag">
            <div class="doc-paper">
                <h2 class="font-display fw-bold mb-2">@doc.Title</h2>
                @if (!string.IsNullOrWhiteSpace(doc.Description))
                {
                    <p class="text-muted-edurag mb-3">@doc.Description</p>
                }
                <p class="small text-muted-edurag mb-4">
                    @doc.OriginalFileName
                    · @DocumentModel.FormatFileSize(doc.FileSize)
                    · @doc.TotalChunks chunk@(doc.TotalChunks == 1 ? "" : "s") (RAG)
                </p>

                @if (!string.IsNullOrEmpty(doc.PreviewMessage) && chunk == null)
                {
                    <div class="alert alert-warning small">@doc.PreviewMessage</div>
                }

                @if (chunk != null)
                {
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2 small text-muted-edurag">
                        <span class="citation-chip">
                            Chunk #@chunk.ChunkIndex
                            @(chunk.PageNumber.HasValue ? $"· trang {chunk.PageNumber}" : "")
                        </span>
                        <span>~@chunk.TokenEstimate token · @chunk.CharCount ký tự</span>
                    </div>
                    <div class="border rounded-3 p-3 small bg-white" style="white-space:pre-wrap;max-height:520px;overflow:auto;">@chunk.ChunkText</div>
                    @if (doc.Chunks.Count > 1)
                    {
                        <div class="d-flex justify-content-between align-items-center mt-3 gap-2">
                            @{
                                var ordered = doc.Chunks.OrderBy(c => c.ChunkIndex).ToList();
                                var idx = ordered.FindIndex(c => c.ChunkIndex == chunk.ChunkIndex);
                                var prev = idx > 0 ? ordered[idx - 1] : null;
                                var next = idx >= 0 && idx < ordered.Count - 1 ? ordered[idx + 1] : null;
                            }
                            @if (prev != null)
                            {
                                <a asp-page="/Student/Document" asp-route-id="@doc.DocumentId" asp-route-chunk="@prev.ChunkIndex"
                                   class="btn btn-sm btn-edurag-ghost">← Chunk #@prev.ChunkIndex</a>
                            }
                            else
                            {
                                <span></span>
                            }
                            <span class="small text-muted-edurag">@((idx + 1)) / @doc.Chunks.Count</span>
                            @if (next != null)
                            {
                                <a asp-page="/Student/Document" asp-route-id="@doc.DocumentId" asp-route-chunk="@next.ChunkIndex"
                                   class="btn btn-sm btn-edurag-ghost">Chunk #@next.ChunkIndex →</a>
                            }
                        </div>
                    }
                }
                else if (doc.TotalChunks > 0)
                {
                    <p class="text-muted-edurag mb-0">
                        Không trích xuất được text preview từ file gốc (có thể là bản scan).
                        RAG vẫn có @doc.TotalChunks chunks —
                        dùng <a asp-page="/Student/Chat" asp-route-documentId="@doc.DocumentId">Hỏi đáp</a> để truy vấn.
                    </p>
                }
                else
                {
                    <p class="text-muted-edurag mb-0">Chưa có nội dung preview.</p>
                }
            </div>
        </div>
        <div class="col-lg-4 p-4 overflow-auto" style="background:var(--edurag-sidebar);">
            <h3 class="font-display fw-bold fs-6 mb-1">Thông tin</h3>
            <dl class="small mb-4">
                @if (!string.IsNullOrWhiteSpace(doc.CourseName))
                {
                    <dt class="text-muted-edurag">Môn học</dt>
                    <dd class="mb-2">@doc.CourseName (@doc.CourseCode)</dd>
                }
                <dt class="text-muted-edurag">Người upload</dt>
                <dd class="mb-2">@doc.SubmittedByDisplay</dd>
                <dt class="text-muted-edurag">Tải lên</dt>
                <dd class="mb-2">@doc.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                @if (doc.IndexedAt.HasValue)
                {
                    <dt class="text-muted-edurag">Index</dt>
                    <dd class="mb-0">@doc.IndexedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                }
            </dl>

            <h3 class="font-display fw-bold fs-6 mb-1">Hỏi về tài liệu này</h3>
            <p class="small text-muted-edurag mb-3">Trợ lý chỉ trả lời trong phạm vi nội dung đã index.</p>
            <a asp-page="/Student/Chat" asp-route-documentId="@doc.DocumentId" class="btn btn-edurag-warm w-100 mb-3">Mở chat đầy đủ</a>

            @if (doc.Chunks.Any())
            {
                <hr />
                <p class="small fw-semibold text-muted-edurag text-uppercase mb-2" style="letter-spacing:.05em;">Các chunk preview</p>
                <ul class="list-unstyled small mb-0">
                    @foreach (var c in doc.Chunks.OrderBy(x => x.ChunkIndex).Take(12))
                    {
                        var isActive = chunk != null && c.ChunkIndex == chunk.ChunkIndex;
                        <li class="mb-2">
                            <a asp-page="/Student/Document" asp-route-id="@doc.DocumentId" asp-route-chunk="@c.ChunkIndex"
                               class="citation-chip text-decoration-none @(isActive ? "active" : "")">
                                #@c.ChunkIndex @(c.PageNumber.HasValue ? $"· tr.{c.PageNumber}" : "")
                            </a>
                        </li>
                    }
                </ul>
                @if (doc.Chunks.Count > 12)
                {
                    <p class="small text-muted-edurag mt-2 mb-0">+ @(doc.Chunks.Count - 12) chunk khác</p>
                }
            }
        </div>
    </div>
</div>
