@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = Model.Details.Title;
    Layout = "_LayoutDashboard";
    var doc = Model.Details;
    var previewChunkCount = doc.Chunks.Count;
    var indexResult = Request.Query["indexResult"].ToString();
    var fileType = (doc.FileType ?? string.Empty).TrimStart('.').ToUpperInvariant();
    var statusText = doc.IndexStatus == "Indexed" ? "&#272;&#227; Index" : doc.IndexStatus;
    var fileSizeDisplay = doc.FileSize >= 1024 * 1024
        ? $"{doc.FileSize / 1024d / 1024d:0.##} MB"
        : $"{Math.Max(1, Math.Ceiling(doc.FileSize / 1024d)):0} KB";
}

<div class="edurag-page">
    <div class="d-flex flex-wrap gap-2 mb-3">
        <a asp-page="@Model.BackPage" class="btn btn-sm btn-edurag-ghost">@Model.BackLabel</a>
        @if (doc.CanReIndex)
        {
            <form asp-page-handler="ReIndex" asp-route-id="@doc.DocumentId" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-edurag-outline">Re-index / Re-chunk</button>
            </form>
        }
    </div>

    @if (string.IsNullOrEmpty(indexResult) && TempData["Success"] != null)
    {
        <div class="alert alert-success mb-3">@TempData["Success"]</div>
    }
    @if (string.IsNullOrEmpty(indexResult) && TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-3">@TempData["Error"]</div>
    }

    <h1 class="font-display fs-4 fw-bold mb-1">@doc.Title</h1>
    <p class="text-muted-edurag small mb-3">
        @doc.CourseCode
        @if (!string.IsNullOrWhiteSpace(doc.Chapter))
        {
            <span> - @doc.Chapter</span>
        }
        <span> - @doc.OriginalFileName - @fileType - </span>
        <span class="@(doc.IndexStatus == "Indexed" ? "status-badge-indexed" : doc.IndexStatus == "Failed" ? "status-badge-failed" : "pill-filter")">@Html.Raw(statusText)</span>
    </p>

    @if (!string.IsNullOrWhiteSpace(doc.Description))
    {
        <div class="edurag-card p-3 mb-3 small">@doc.Description</div>
    }

    <div class="document-detail-grid">
        <aside class="document-info-panel">
            <div class="document-panel-heading">
                <h2 class="document-panel-title">&#128196; Th&#244;ng tin t&#224;i li&#7879;u</h2>
            </div>
            <div class="document-file-mark">@(string.IsNullOrWhiteSpace(fileType) ? "FILE" : fileType)</div>
            <dl class="document-meta">
                <div><dt>Ti&#234;u &#273;&#7873;</dt><dd>@doc.Title</dd></div>
                <div><dt>M&#244;n h&#7885;c</dt><dd>[@doc.CourseCode] @doc.CourseName</dd></div>
                <div><dt>Ch&#432;&#417;ng</dt><dd>@(string.IsNullOrWhiteSpace(doc.Chapter) ? "-" : doc.Chapter)</dd></div>
                <div><dt>K&#237;ch th&#432;&#7899;c</dt><dd>@fileSizeDisplay</dd></div>
                <div><dt>Upload b&#7903;i</dt><dd>@doc.SubmittedByDisplay</dd></div>
                <div><dt>Ng&#224;y upload</dt><dd>@doc.CreatedAt.ToLocalTime().ToString("g")</dd></div>
                <div><dt>Th&#7901;i gian index</dt><dd>@(doc.IndexedAt.HasValue ? doc.IndexedAt.Value.ToLocalTime().ToString("g") : "-")</dd></div>
                <div><dt>Tr&#7841;ng th&#225;i</dt><dd><span class="@(doc.IndexStatus == "Indexed" ? "status-badge-indexed" : doc.IndexStatus == "Failed" ? "status-badge-failed" : "pill-filter")">@Html.Raw(statusText)</span></dd></div>
            </dl>
        </aside>

        <section class="document-chunk-panel" id="chunk-preview">
            <div class="document-panel-heading">
                <div class="document-panel-title">
                    <span aria-hidden="true">&#9638;</span>
                    <span>Document Chunks</span>
                    <span class="document-chunk-count">@previewChunkCount</span>
                </div>
                <span class="small text-muted-edurag">N&#7897;i dung t&#225;ch &#273;&#7875; ph&#7909;c v&#7909; AI/RAG</span>
            </div>

            @if (doc.Chunks.Any())
            {
                <div class="document-chunk-list">
                    @foreach (var chunk in doc.Chunks)
                    {
                        <article class="document-chunk-item">
                            <header class="document-chunk-header">
                                <div class="document-chunk-header-group">
                                    <span class="document-chunk-number">#@(chunk.ChunkIndex + 1)</span>
                                    @if (chunk.PageNumber.HasValue)
                                    {
                                        <span class="document-chunk-page">&#128196; Trang @chunk.PageNumber</span>
                                    }
                                </div>
                                <div class="document-chunk-header-group">
                                    <span class="document-chunk-state">&#9679; @(doc.IndexStatus == "Indexed" ? "Embedded" : "Preview")</span>
                                    <span class="document-chunk-size">@chunk.CharCount k&#253; t&#7921;</span>
                                </div>
                            </header>
                            <div class="document-chunk-text">@chunk.ChunkText</div>
                        </article>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(doc.PreviewMessage))
            {
                <p class="m-3 text-muted-edurag">@doc.PreviewMessage</p>
            }
            else
            {
                <p class="m-3 text-muted-edurag">Ch&#432;a c&#243; chunk n&#7897;i dung.</p>
            }
        </section>
    </div>
</div>
