@page
@using AcademicDocumentRagSystem.Services.DTOs.Courses
@using AcademicDocumentRagSystem.Services.DTOs.Documents
@model AcademicDocumentRagSystem.RazorPages.Pages.Documents.AllModel
@{
    ViewData["Title"] = "Tài liệu";
    Layout = "_LayoutDashboard";
    var uploadStatus = HttpContext.Request.Query["UploadStatus"].FirstOrDefault();
    var totalDocuments = Model.Documents?.Count ?? 0;
    var indexedDocuments = Model.Documents?.Count(d => d.IndexStatus == "Indexed") ?? 0;
    var totalChunks = Model.Documents?.Sum(d => d.TotalChunks) ?? 0;
    var uploadStatuses = new[] { "Submitted", "Approved", "Deleted" };
    var indexStatuses = new[] { "Pending", "Processing", "Indexed", "Failed" };
}

<div class="p-4 p-md-5">
    <div class="mb-4">
        <h1 class="font-display fs-2 fw-bold mb-1">Tất cả tài liệu</h1>
        <p class="text-muted-edurag mb-0">Danh sách tài liệu đã upload trên toàn hệ thống</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="edurag-card p-4">
                <div class="small text-muted-edurag text-uppercase fw-semibold mb-1">Tài liệu</div>
                <div class="font-display fs-3 fw-bold">@totalDocuments</div>
                <div class="small text-muted-edurag">Theo bộ lọc hiện tại</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="edurag-card p-4">
                <div class="small text-muted-edurag text-uppercase fw-semibold mb-1">Đã index</div>
                <div class="font-display fs-3 fw-bold text-gradient-warm">@indexedDocuments</div>
                <div class="small text-muted-edurag">Sẵn sàng cho Q&amp;A</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="edurag-card p-4">
                <div class="small text-muted-edurag text-uppercase fw-semibold mb-1">Chunks</div>
                <div class="font-display fs-3 fw-bold">@totalChunks</div>
                <div class="small text-muted-edurag">Đơn vị retrieval RAG</div>
            </div>
        </div>
    </div>

    <div class="edurag-card p-3 mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold" for="CourseId">Môn học</label>
                <select class="form-select form-select-sm" id="CourseId" name="CourseId">
                    <option value="">Tất cả môn</option>
                    @foreach (var course in Model.Courses)
                    {
                        if (Model.CourseId == course.CourseId)
                        {
                            <option value="@course.CourseId" selected>@course.Code — @course.Name</option>
                        }
                        else
                        {
                            <option value="@course.CourseId">@course.Code — @course.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold" for="UploadStatus">Upload</label>
                <select class="form-select form-select-sm" id="UploadStatus" name="UploadStatus">
                    <option value="">Bất kỳ</option>
                    @foreach (var status in uploadStatuses)
                    {
                        if (uploadStatus == status) { <option value="@status" selected>@status</option> }
                        else { <option value="@status">@status</option> }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold" for="IndexStatus">Index</label>
                <select class="form-select form-select-sm" id="IndexStatus" name="IndexStatus">
                    <option value="">Bất kỳ</option>
                    @foreach (var status in indexStatuses)
                    {
                        if (Model.IndexStatus == status) { <option value="@status" selected>@status</option> }
                        else { <option value="@status">@status</option> }
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-edurag-outline">Lọc</button>
                <a asp-page="/Documents/All" class="btn btn-sm btn-edurag-ghost">Đặt lại</a>
            </div>
        </form>
    </div>

    <div class="edurag-card overflow-hidden">
        @if (Model.Documents == null || !Model.Documents.Any())
        {
            <div class="text-center text-muted-edurag py-5">Không có tài liệu phù hợp bộ lọc.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table-edurag">
                    <thead>
                        <tr>
                            <th>Tài liệu</th>
                            <th>Môn</th>
                            <th>Chương</th>
                            <th>File</th>
                            <th>Upload</th>
                            <th>Index</th>
                            <th>Chunks</th>
                            <th>Người upload</th>
                            <th>Thời gian</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var document in Model.Documents)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@document.Title</div>
                                    @if (!string.IsNullOrWhiteSpace(document.Description))
                                    {
                                        <div class="small text-muted-edurag">@document.Description</div>
                                    }
                                </td>
                                <td>
                                    <span class="role-badge-teacher">@document.CourseCode</span>
                                    @if (!string.IsNullOrWhiteSpace(document.CourseName))
                                    {
                                        <div class="small text-muted-edurag">@document.CourseName</div>
                                    }
                                </td>
                                <td class="small">@(string.IsNullOrWhiteSpace(document.Chapter) ? "—" : document.Chapter)</td>
                                <td>
                                    <div class="small fw-semibold">@document.OriginalFileName</div>
                                    <div class="small text-muted-edurag">@document.FileType.ToUpperInvariant() · @(Math.Ceiling(document.FileSize / 1024.0)) KB</div>
                                </td>
                                <td><span class="pill-filter">@document.UploadStatus</span></td>
                                <td>
                                    <span class="@(document.IndexStatus == "Indexed" ? "status-badge-indexed" : document.IndexStatus == "Failed" ? "status-badge-failed" : "pill-filter")">
                                        @document.IndexStatus
                                    </span>
                                </td>
                                <td class="small">@document.TotalChunks</td>
                                <td>
                                    <div class="small">@(string.IsNullOrWhiteSpace(document.SubmittedByFullName) ? "—" : document.SubmittedByFullName)</div>
                                    <div class="small text-muted-edurag">@(string.IsNullOrWhiteSpace(document.SubmittedByEmail) ? "" : document.SubmittedByEmail)</div>
                                </td>
                                <td class="small text-muted-edurag">
                                    <div>@document.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                    @if (document.IndexedAt.HasValue)
                                    {
                                        <div>Index: @document.IndexedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-page="/Documents/Details" asp-route-id="@document.DocumentId" class="btn btn-sm btn-edurag-ghost">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
