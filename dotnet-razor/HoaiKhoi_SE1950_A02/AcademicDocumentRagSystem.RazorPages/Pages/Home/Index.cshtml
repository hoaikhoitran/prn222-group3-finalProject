@page
@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_LayoutPublic";
}
<script>document.documentElement.classList.add('home-reveal-ready');</script>
@await Html.PartialAsync("_SiteHeader")

<div class="home-intro position-relative overflow-hidden">
    <div class="position-absolute top-0 start-0 w-100 h-100 grid-bg"></div>
<section class="position-relative">
    <div class="edurag-container position-relative text-center" style="padding-top:5.5rem;padding-bottom:3.5rem;" data-home-stagger>
        <span class="section-chip mb-4" data-home-reveal>
            @{ ViewData["Icon"] = "sparkles"; ViewData["IconSize"] = "13"; }
            @await Html.PartialAsync("_Icons")
            Research-Based Learning · RAG cho tài liệu học thuật
        </span>
        <h1 class="font-display display-3 fw-bold lh-sm mb-3 mx-auto mt-3" style="max-width:46rem;" data-home-reveal>
            Hỏi đáp tài liệu môn học — <span class="text-gradient-warm">rõ ràng, có trích dẫn.</span>
        </h1>
        <p class="fs-5 text-muted-edurag mb-4 mx-auto" style="max-width:38rem;line-height:1.65;" data-home-reveal>
            EduRAG giúp sinh viên và giảng viên tra cứu slide, giáo trình, PDF bằng ngôn ngữ tự nhiên.
            Mỗi câu trả lời gắn với nguồn trong tài liệu đã upload — không bịa, không lan man.
        </p>
        <div class="d-flex flex-wrap justify-content-center gap-2 mb-5" data-home-reveal>
            <a asp-page="/Auth/Login" class="btn btn-lg btn-edurag-warm d-inline-flex align-items-center gap-2">
                Bắt đầu ngay
                @{ ViewData["Icon"] = "arrow-right"; ViewData["IconSize"] = "16"; }
                @await Html.PartialAsync("_Icons")
            </a>
            <a href="/#features" class="btn btn-lg btn-edurag-outline">Khám phá tính năng</a>
        </div>
        <div class="row g-4 justify-content-center mx-auto" style="max-width:40rem;" data-home-reveal>
            @foreach (var s in new[] { ("PDF · DOCX · PPTX", "Định dạng hỗ trợ"), ("bge-m3", "Embedding đa ngữ"), ("100%", "Câu trả lời có nguồn"), ("3", "Vai trò người dùng") })
            {
                <div class="col-6 col-md-3">
                    <div class="font-display fs-4 fw-bold text-gradient-warm">@s.Item1</div>
                    <div class="small text-muted-edurag">@s.Item2</div>
                </div>
            }
        </div>
    </div>
</section>

<section class="edurag-container position-relative pb-5">
    <div class="edurag-card overflow-hidden shadow-soft" data-home-reveal>
        <div class="d-flex align-items-center gap-2 px-3 py-2 border-bottom small text-muted-edurag" style="border-color:var(--edurag-border)!important;background:var(--edurag-sidebar);">
            <span class="rounded-circle" style="width:8px;height:8px;background:#e07a5f;"></span>
            <span class="rounded-circle" style="width:8px;height:8px;background:#f2cc8f;"></span>
            <span class="rounded-circle" style="width:8px;height:8px;background:#81b29a;"></span>
            <span class="ms-2 font-monospace">edurag · student / chat</span>
        </div>
        <div class="row g-0" style="min-height:380px;">
            <div class="col-md-4 border-end p-3" style="background:var(--edurag-sidebar);border-color:var(--edurag-border)!important;">
                <div class="small fw-semibold text-muted-edurag text-uppercase mb-2" style="font-size:11px;letter-spacing:.06em;">Gần đây</div>
                <div class="chat-conv-item active mb-1">Sự khác nhau AI/ML</div>
                <div class="chat-conv-item mb-1">Thuật toán A* heuristic</div>
                <div class="chat-conv-item mb-1">Tóm tắt chương 2</div>
                <div class="chat-conv-item">Ôn tập giữa kỳ</div>
            </div>
            <div class="col-md-8 p-4 p-md-5">
                <div class="d-flex justify-content-end mb-4">
                    <div class="chat-bubble-user">Sự khác nhau giữa AI và Machine Learning là gì?</div>
                </div>
                <div class="d-flex gap-3">
                    <div class="chat-avatar">
                        @{ ViewData["Icon"] = "sparkles"; ViewData["IconSize"] = "16"; }
                        @await Html.PartialAsync("_Icons")
                    </div>
                    <div>
                        <div class="chat-bubble-assistant mb-2">AI là lĩnh vực rộng nghiên cứu cách tạo hệ thống thông minh; Machine Learning là một nhánh tập trung vào việc học từ dữ liệu. Theo giáo trình chương 1, mọi hệ ML đều là AI nhưng không phải AI nào cũng dùng ML…</div>
                        <span class="citation-chip me-1">
                            @{ ViewData["Icon"] = "quote"; ViewData["IconSize"] = "11"; }
                            @await Html.PartialAsync("_Icons")
                            Chương 1.pdf · tr.12
                        </span>
                        <span class="citation-chip">
                            @{ ViewData["Icon"] = "quote"; ViewData["IconSize"] = "11"; }
                            @await Html.PartialAsync("_Icons")
                            Russell &amp; Norvig.pdf · tr.4
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
</div>

<section id="features" class="edurag-container py-5">
    <div class="text-center mb-5" data-home-reveal>
        <span class="section-chip">Tính năng</span>
        <h2 class="font-display display-6 fw-bold mt-3 mb-2">Một nền tảng cho lớp học hiện đại.</h2>
        <p class="text-muted-edurag mx-auto" style="max-width:34rem;">Từ upload tài liệu đến hỏi đáp có trích dẫn — mọi bước trong một hệ thống duy nhất.</p>
    </div>
    <div class="row g-3" data-home-stagger>
        @foreach (var f in new[] {
            ("file", "Quản lý tài liệu", "Upload PDF, DOCX, PPTX, TXT. Tự động chunk & embed theo môn học, chương."),
            ("message", "Chat có trích dẫn", "Trả lời tự nhiên kèm nguồn trang cụ thể. Giới hạn trong phạm vi tài liệu lớp."),
            ("zap", "Index realtime", "Theo dõi pipeline chunk → embedding → vector store với trạng thái trực quan."),
            ("layers", "Chunk config linh hoạt", "Admin điều chỉnh chiến lược chunking toàn hệ thống, preview trước khi áp dụng."),
            ("clock", "Lịch sử hội thoại", "Phiên chat lưu theo môn và tài liệu, dễ dàng quay lại tra cứu."),
            ("shield", "Phân quyền rõ ràng", "Admin, giảng viên, sinh viên — mỗi vai trò một không gian làm việc riêng.") })
        {
            <div class="col-md-6 col-lg-4" data-home-reveal>
                <div class="edurag-card p-4 h-100 feature-card">
                    <span class="stat-card__icon stat-card__icon--warm mb-3">
                        @{ ViewData["Icon"] = f.Item1; ViewData["IconSize"] = "20"; }
                        @await Html.PartialAsync("_Icons")
                    </span>
                    <h3 class="font-display fw-bold fs-5 mb-2">@f.Item2</h3>
                    <p class="small text-muted-edurag mb-0" style="line-height:1.6;">@f.Item3</p>
                </div>
            </div>
        }
    </div>
</section>

<section class="py-5" style="background:var(--edurag-sidebar);border-top:1px solid var(--edurag-border);border-bottom:1px solid var(--edurag-border);">
    <div class="edurag-container">
        <div class="text-center mb-5" data-home-reveal>
            <span class="section-chip">Ba vai trò</span>
            <h2 class="font-display display-6 fw-bold mt-3">Một nền tảng, ba trải nghiệm.</h2>
        </div>
        <div class="row g-3" data-home-stagger>
            @foreach (var r in new[] {
                ("book", "Sinh viên", "Chat với tài liệu, xem giáo trình theo chunk, lưu hội thoại theo môn học."),
                ("graduation", "Giảng viên", "Upload tài liệu, theo dõi trạng thái index, kiểm thử chatbot trước khi phát hành."),
                ("shield", "Admin", "Quản lý tài khoản, môn học realtime, cấu hình chunking toàn hệ thống.") })
            {
                <div class="col-md-4" data-home-reveal>
                    <div class="edurag-card p-4 feature-card h-100 text-center">
                        <span class="stat-card__icon stat-card__icon--warm mx-auto mb-3">
                            @{ ViewData["Icon"] = r.Item1; ViewData["IconSize"] = "20"; }
                            @await Html.PartialAsync("_Icons")
                        </span>
                        <h3 class="font-display fw-bold fs-4 mb-2">@r.Item2</h3>
                        <p class="small text-muted-edurag mb-0" style="line-height:1.6;">@r.Item3</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="research" class="edurag-container py-5">
    <div class="col-lg-8" data-home-stagger>
        <span class="section-chip" data-home-reveal>Nghiên cứu</span>
        <h2 class="font-display display-6 fw-bold mt-3 mb-3" data-home-reveal>RAG cho tài liệu học thuật tiếng Việt.</h2>
        <p class="text-muted-edurag mb-4" style="max-width:36rem;line-height:1.7;" data-home-reveal>
            Pipeline embedding + retrieval giới hạn trong corpus lớp học, nhằm giảm hallucination
            và tăng độ tin cậy khi ôn tập. Đánh giá trên test set ground-truth do giảng viên chuẩn bị.
        </p>
        <div class="d-flex flex-wrap gap-2" data-home-reveal>
            @foreach (var step in new[] { "Upload", "Chunk", "Embed", "Retrieve", "Answer + Cite" })
            {
                <span class="citation-chip">@step</span>
            }
        </div>
    </div>
</section>

<section class="edurag-container pb-5">
    <div class="rounded-4 bg-gradient-hero text-white text-center p-5 shadow-glow position-relative overflow-hidden" data-home-reveal>
        <div class="grid-bg position-absolute top-0 start-0 w-100 h-100" style="opacity:.3;"></div>
        <div class="position-relative">
            <h2 class="font-display display-6 fw-bold mb-2">Sẵn sàng học thông minh hơn?</h2>
            <p class="opacity-85 mb-4 mx-auto" style="max-width:30rem;">Đăng nhập để hỏi đáp trên tài liệu môn học của bạn — có nguồn, có kiểm chứng.</p>
            <a asp-page="/Auth/Login" class="btn btn-light btn-lg px-4">Đăng nhập</a>
        </div>
    </div>
</section>

@await Html.PartialAsync("_SiteFooter")

@section Scripts {
    <script src="~/js/home-reveal.js" asp-append-version="true"></script>
}
