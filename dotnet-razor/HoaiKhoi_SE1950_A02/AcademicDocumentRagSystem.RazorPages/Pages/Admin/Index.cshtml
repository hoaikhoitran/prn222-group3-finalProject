@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Thống kê hệ thống";
    Layout = "_LayoutDashboard";
    var monthNames = new[] { "Tháng 1", "Tháng 2", "Tháng 3", "Tháng 4", "Tháng 5", "Tháng 6", "Tháng 7", "Tháng 8", "Tháng 9", "Tháng 10", "Tháng 11", "Tháng 12" };
}

<div class="p-4 p-md-5">
    <div class="mb-4">
        <h1 class="font-display fs-2 fw-bold mb-1">Hệ thống Báo cáo &amp; Thống kê</h1>
        <p class="text-muted-edurag mb-0">Tổng quan vận hành cơ sở dữ liệu học thuật và hiệu năng phân đoạn dữ liệu.</p>
    </div>

    @* ------- Bộ lọc tháng / năm (GET query để reload/chia sẻ URL) ------- *@
    <div class="edurag-card p-3 mb-4">
        <form method="get" class="d-flex flex-wrap align-items-end gap-3">
            <div>
                <label for="filter-year" class="form-label small fw-semibold text-muted-edurag mb-1">Năm</label>
                <select id="filter-year" name="year" class="form-select form-select-sm" style="min-width:8rem;">
                    <option value="">— Tất cả —</option>
                    @foreach (var y in Model.Statistics.AvailableYears)
                    {
                        <option value="@y" selected="@(Model.SelectedYear == y)">@y</option>
                    }
                </select>
            </div>
            <div>
                <label for="filter-month" class="form-label small fw-semibold text-muted-edurag mb-1">Tháng</label>
                <select id="filter-month" name="month" class="form-select form-select-sm" style="min-width:8rem;"
                        disabled="@(Model.SelectedYear == null)">
                    <option value="">— Cả năm —</option>
                    @for (var m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(Model.SelectedMonth == m)">@monthNames[m - 1]</option>
                    }
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-edurag-warm">Áp dụng</button>
                <a asp-page="/Admin/Index" class="btn btn-sm btn-edurag-outline">Tất cả thời gian</a>
            </div>
            <div class="ms-auto text-end">
                <div class="small text-muted-edurag">Đang xem</div>
                <div class="fw-bold">@Model.ScopeLabel</div>
            </div>
        </form>
        @if (!string.IsNullOrEmpty(Model.FilterWarning))
        {
            <div class="alert alert-warning py-2 small mt-3 mb-0">@Model.FilterWarning</div>
        }
    </div>

    <div class="row g-3 mb-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5">
        <div class="col">
            <div class="edurag-card p-3 h-100 style-card-stat" style="background-color: #f4f7fe;">
                <div class="text-muted-edurag fw-semibold small text-uppercase mb-1">Tài khoản <span class="fw-normal">(toàn hệ thống)</span></div>
                <div class="fs-3 fw-bold text-dark">@Model.Statistics.TotalAccounts</div>
            </div>
        </div>
        <div class="col">
            <div class="edurag-card p-3 h-100 style-card-stat" style="background-color: #fef6f0;">
                <div class="text-muted-edurag fw-semibold small text-uppercase mb-1">Môn học <span class="fw-normal">(toàn hệ thống)</span></div>
                <div class="fs-3 fw-bold text-dark">@Model.Statistics.TotalCourses</div>
            </div>
        </div>
        <div class="col">
            <div class="edurag-card p-3 h-100 style-card-stat" style="background-color: #eef9f5;">
                <div class="text-muted-edurag fw-semibold small text-uppercase mb-1">Tài liệu gốc</div>
                <div class="fs-3 fw-bold text-dark">@Model.Statistics.TotalDocuments</div>
            </div>
        </div>
        <div class="col">
            <div class="edurag-card p-3 h-100 style-card-stat" style="background-color: #f6f8fa;">
                <div class="text-muted-edurag fw-semibold small text-uppercase mb-1">Phiên chat</div>
                <div class="fs-3 fw-bold text-dark">@Model.Statistics.TotalChatSessions</div>
            </div>
        </div>
        <div class="col">
            <div class="edurag-card p-3 h-100 style-card-stat" style="background-color: #fbf2ff;">
                <div class="text-muted-edurag fw-semibold small text-uppercase mb-1">Tin nhắn</div>
                <div class="fs-3 fw-bold text-dark">@Model.Statistics.TotalChatMessages</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-4 d-flex flex-column gap-4">
            <div class="edurag-card p-4">
                <h3 class="font-display fs-5 fw-bold mb-1">Trạng thái RAG Indexing</h3>
                <p class="text-muted-edurag small mb-4">Trạng thái xử lý các tài liệu đã tải lên hệ thống.</p>

                <div class="mx-auto mb-4" style="max-width: 240px; position: relative;">
                    <canvas id="rag-status-chart" aria-label="Biểu đồ trạng thái RAG Indexing" role="img"></canvas>
                    <div id="rag-status-chart-empty" class="text-center text-muted-edurag small py-4" hidden>
                        Chưa có tài liệu nào để thống kê.
                    </div>
                </div>

                <div class="d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between align-items-center p-3 rounded-3" style="background-color: #f8f9fa;">
                        <span class="text-secondary fw-medium"><span class="me-2"></span>Đang chờ (Pending)</span>
                        <span class="status-badge-pending px-3 py-1.5 fs-6">@Model.Statistics.DocsPending</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 rounded-3" style="background-color: #e8f4fd;">
                        <span class="text-primary fw-medium"><span class="me-2"></span>Đang xử lý</span>
                        <span class="status-badge-processing px-3 py-1.5 fs-6">@Model.Statistics.DocsProcessing</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 rounded-3" style="background-color: #eafaf1;">
                        <span class="text-success fw-medium"><span class="me-2"></span>Thành công (Indexed)</span>
                        <span class="status-badge-indexed px-3 py-1.5 fs-6">@Model.Statistics.DocsIndexed</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 rounded-3" style="background-color: #fdf2f2;">
                        <span class="text-danger fw-medium"><span class="me-2"></span>Thất bại (Failed)</span>
                        <span class="status-badge-failed px-3 py-1.5 fs-6">@Model.Statistics.DocsFailed</span>
                    </div>
                </div>
            </div>

            <div class="edurag-card p-4">
                <h3 class="font-display fs-5 fw-bold mb-1">Token dùng để trả lời câu hỏi</h3>
                <p class="text-muted-edurag small mb-3">Số token Gemini thực tế sử dụng khi tiếp nhận câu hỏi và tạo câu trả lời.</p>

                <div class="d-flex flex-column gap-3">
                    <div class="p-3 rounded-3" style="background-color: #f4f7fe;">
                        <div class="text-muted-edurag small fw-semibold text-uppercase">Token đầu vào</div>
                        <div class="fs-4 fw-bold text-dark mt-1">@Model.Statistics.TotalPromptTokens.ToString("N0") <span class="fs-7 text-secondary fw-normal">tokens</span></div>
                    </div>
                    <div class="p-3 rounded-3" style="background-color: #fbf2ff;">
                        <div class="text-muted-edurag small fw-semibold text-uppercase">Token câu trả lời</div>
                        <div class="fs-4 fw-bold text-dark mt-1">@Model.Statistics.TotalCompletionTokens.ToString("N0") <span class="fs-7 text-secondary fw-normal">tokens</span></div>
                    </div>
                    <div class="p-3 rounded-3 border border-dashed" style="background-color: #fffde7; border-color: #fdedad !important;">
                        <div class="small fw-bold text-uppercase" style="color: #856404;">Tổng token đã sử dụng</div>
                        <div class="fs-3 fw-bold mt-1" style="color: #856404;">@Model.Statistics.TotalLlmTokens.ToString("N0") <span class="fs-6 fw-normal">tokens</span></div>
                    </div>
                </div>
            </div>

            <div class="edurag-card p-4">
                <h3 class="font-display fs-5 fw-bold mb-1">Token nội dung tài liệu</h3>
                <p class="text-muted-edurag small mb-3">Ước lượng dựa trên nội dung các chunk đã lưu.</p>
                <div class="p-3 rounded-3" style="background-color: #f6f8fa;">
                    <div class="text-muted-edurag small fw-semibold text-uppercase">Token ước lượng</div>
                    <div class="fs-4 fw-bold text-dark mt-1">@Model.Statistics.ChunkTokenEstimate.ToString("N0") <span class="fs-7 text-secondary fw-normal">tokens</span></div>
                    <div class="small text-muted-edurag mt-1">@Model.Statistics.TotalVectorChunks chunk đã tạo</div>
                </div>
            </div>

            <div class="edurag-card p-4">
                <h3 class="font-display fs-5 fw-bold mb-1">Tổng token hệ thống</h3>
                <p class="text-muted-edurag small mb-3">Tổng token Gemini và token nội dung chunk ước lượng.</p>
                <div class="p-3 rounded-3" style="background-color: #eef9f5;">
                    <div class="fs-3 fw-bold text-dark">@Model.Statistics.TotalSystemTokens.ToString("N0") <span class="fs-6 text-secondary fw-normal">tokens</span></div>
                    <div class="small text-muted-edurag mt-1">= @Model.Statistics.TotalLlmTokens.ToString("N0") Gemini + @Model.Statistics.ChunkTokenEstimate.ToString("N0") chunk ước lượng</div>
                </div>
            </div>

        </div>

        <div class="col-12 col-lg-8 d-flex flex-column gap-4">
            <div class="edurag-card p-4 overflow-hidden">
                <h3 class="font-display fs-5 fw-bold mb-1">Token theo tài khoản</h3>
                <p class="text-muted-edurag small mb-1">Token Gemini tính cho tài khoản đã đặt câu hỏi; token chunk tính cho người upload tài liệu. Phạm vi: <strong>@Model.ScopeLabel</strong>.</p>
                <p class="text-muted-edurag small mb-4">Token Gemini là usage thực tế từ AI; token chunk là số ước lượng nội dung tài liệu đã phân đoạn.</p>

                <div class="table-responsive">
                    <table class="table-edurag align-middle m-0">
                        <thead>
                            <tr>
                                <th>Người dùng</th>
                                <th>Vai trò</th>
                                <th class="text-center">Số câu hỏi</th>
                                <th class="text-end">Token đầu vào</th>
                                <th class="text-end">Token câu trả lời</th>
                                <th class="text-end">Tổng token Gemini</th>
                                <th class="text-center">Số chunk</th>
                                <th class="text-end">Token chunk ước lượng</th>
                                <th class="text-end">Tổng token hệ thống</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Statistics.UserTokenReports.Any())
                            {
                                foreach (var user in Model.Statistics.UserTokenReports)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold text-dark">@user.FullName</div>
                                            @if (!string.IsNullOrEmpty(user.Email))
                                            {
                                                <div class="small text-muted-edurag">@user.Email</div>
                                            }
                                        </td>
                                        <td>
                                            <span class="@(user.RoleName == "Teacher" ? "role-badge-teacher" : "badge rounded-pill bg-light text-dark border") px-2 py-1">@user.RoleName</span>
                                        </td>
                                        <td class="text-center">@user.MessageCount</td>
                                        <td class="text-end">@user.PromptTokens.ToString("N0")</td>
                                        <td class="text-end">@user.CompletionTokens.ToString("N0")</td>
                                        <td class="text-end">@user.TotalTokens.ToString("N0")</td>
                                        <td class="text-center">@user.ChunkCount.ToString("N0")</td>
                                        <td class="text-end">@user.ChunkTokenEstimate.ToString("N0")</td>
                                        <td class="text-end fw-bold">@user.CombinedTotalTokens.ToString("N0")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center py-4 text-muted-edurag">Không có dữ liệu token nào trong phạm vi @Model.ScopeLabel.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="edurag-card p-4 overflow-hidden">
                <h3 class="font-display fs-5 fw-bold mb-1">Báo cáo hoạt động theo Môn học</h3>
                <p class="text-muted-edurag small mb-4">Top các môn học theo tương tác trong phạm vi: <strong>@Model.ScopeLabel</strong>.</p>

                <div class="table-responsive">
                    <table class="table-edurag align-middle m-0">
                        <thead>
                            <tr>
                                <th>Mã môn</th>
                                <th>Tên môn học</th>
                                <th class="text-center">Tài liệu</th>
                                <th class="text-center">Phiên chat</th>
                                <th class="text-center">Tin nhắn</th>
                                <th class="text-end">Tokens</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Statistics.CourseReports != null && Model.Statistics.CourseReports.Any())
                            {
                                foreach (var report in Model.Statistics.CourseReports)
                                {
                                    <tr>
                                        <td class="fw-bold text-primary">@report.CourseCode</td>
                                        <td class="fw-medium text-dark">@report.CourseName</td>
                                        <td class="text-center">
                                            <span class="badge rounded-pill bg-light text-dark border px-2 py-1">@report.DocumentCount</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge px-2.5 py-1.5 rounded-3 fw-semibold" style="background-color: #fff4ec; color: #f26522;">
                                                @report.ChatSessionCount
                                            </span>
                                        </td>
                                        <td class="text-center">@report.ChatMessageCount</td>
                                        <td class="text-end fw-semibold">@report.TotalTokens.ToString("N0")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted-edurag">Chưa có dữ liệu thống kê môn học trong phạm vi @Model.ScopeLabel.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .style-card-stat {
        transition: transform 0.2s ease;
    }

        .style-card-stat:hover {
            transform: translateY(-2px);
        }

    .status-badge-pending {
        background-color: #f3f4f6;
        color: #4b5563;
        border-radius: 6px;
        font-weight: 600;
    }

    .status-badge-processing {
        background-color: #e0f2fe;
        color: #0369a1;
        border-radius: 6px;
        font-weight: 600;
    }
</style>

<script>
    // Month is only selectable once a year is chosen; clearing the year
    // clears + disables the month so ?month never travels without ?year.
    (function () {
        var yearSelect = document.getElementById("filter-year");
        var monthSelect = document.getElementById("filter-month");
        if (!yearSelect || !monthSelect) { return; }
        yearSelect.addEventListener("change", function () {
            var hasYear = !!yearSelect.value;
            monthSelect.disabled = !hasYear;
            if (!hasYear) { monthSelect.value = ""; }
        });
    })();
</script>

<script src="~/lib/chartjs/chart.umd.min.js" asp-append-version="true"></script>
<script>
    // Doughnut chart mirrors the four indexing-status counters already
    // rendered in the card; it never queries anything on its own.
    (function () {
        var canvas = document.getElementById("rag-status-chart");
        var emptyNote = document.getElementById("rag-status-chart-empty");
        if (!canvas || typeof Chart === "undefined") { return; }

        var counts = [
            @Model.Statistics.DocsPending,
            @Model.Statistics.DocsProcessing,
            @Model.Statistics.DocsIndexed,
            @Model.Statistics.DocsFailed
        ];
        var total = counts.reduce(function (sum, n) { return sum + n; }, 0);

        if (total === 0) {
            canvas.hidden = true;
            if (emptyNote) { emptyNote.hidden = false; }
            return;
        }

        var labels = ["Đang chờ", "Đang xử lý", "Thành công", "Thất bại"];
        new Chart(canvas, {
            type: "doughnut",
            data: {
                labels: labels.map(function (label, i) { return label + " (" + counts[i] + ")"; }),
                datasets: [{
                    data: counts,
                    backgroundColor: ["#9ca3af", "#0ea5e9", "#10b981", "#ef4444"],
                    borderColor: "#ffffff",
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                cutout: "62%",
                plugins: {
                    legend: {
                        position: "bottom",
                        labels: { boxWidth: 12, font: { size: 12 } }
                    },
                    tooltip: {
                        callbacks: {
                            label: function (ctx) {
                                var value = ctx.parsed;
                                var pct = Math.round((value / total) * 100);
                                return " " + value + " tài liệu (" + pct + "%)";
                            }
                        }
                    }
                }
            }
        });
    })();
</script>
