@page "{id:int?}"
@model AcademicDocumentRagSystem.RazorPages.Pages.Courses.EditModel
@{
    ViewData["Title"] = "Sửa môn học";
    Layout = "_LayoutDashboard";
}

<div class="edurag-page">
    <div class="mb-4">
        <a asp-page="/Courses/Index" class="btn btn-sm btn-edurag-ghost mb-3">← Quay lại</a>
        <h1 class="font-display fs-2 fw-bold mb-1">Sửa môn học</h1>
        <p class="text-muted-edurag mb-0">Cập nhật thông tin môn học và giảng viên phụ trách.</p>
    </div>

    <div class="edurag-card p-4 p-md-5" style="max-width:680px;">
        <form method="post" class="vstack gap-3">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <input type="hidden" asp-for="Input.CourseId" />

            <div>
                <label asp-for="Input.Code" class="form-label fw-semibold">Mã môn</label>
                <input asp-for="Input.Code" class="form-control" />
                <span asp-validation-for="Input.Code" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Input.Name" class="form-label fw-semibold">Tên môn</label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Input.Description" class="form-label fw-semibold">Mô tả</label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Input.TeacherAccountId" class="form-label fw-semibold">Giảng viên phụ trách</label>
                <select asp-for="Input.TeacherAccountId" asp-items="Model.Teachers" class="form-select">
                    <option value="">— Chưa gán —</option>
                </select>
                <div class="form-text text-muted-edurag">
                    Một giảng viên có thể phụ trách nhiều môn. Chọn "Chưa gán" để bỏ giảng viên hiện tại (tài liệu không bị xóa).
                </div>
                <span asp-validation-for="Input.TeacherAccountId" class="text-danger small"></span>
            </div>

            <div class="form-check">
                <input asp-for="Input.Status" class="form-check-input" />
                <label asp-for="Input.Status" class="form-check-label">Môn học hoạt động</label>
            </div>

            <div class="d-flex gap-2 pt-2">
                <button type="submit" class="btn btn-edurag-warm">Lưu</button>
                <a asp-page="/Courses/Index" class="btn btn-edurag-outline">Huỷ</a>
            </div>
        </form>
    </div>
</div>
