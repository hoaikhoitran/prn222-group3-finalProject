@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Môn học";
    Layout = "_LayoutDashboard";
}

<div class="p-4 p-md-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
        <div>
            <h1 class="font-display fs-2 fw-bold mb-1">Quản lý môn học</h1>
            <p class="text-muted-edurag mb-0">Tạo và quản lý các môn học trong hệ thống</p>
        </div>
        <a asp-page="/Courses/Create" class="btn btn-edurag-warm btn-sm d-inline-flex align-items-center gap-1">
            @{ ViewData["Icon"] = "plus"; ViewData["IconSize"] = "14"; }
            @await Html.PartialAsync("_Icons")
            Thêm môn học
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-3">@TempData["Error"]</div>
    }

    <div class="edurag-card overflow-hidden">
        @if (Model.Courses == null || !Model.Courses.Any())
        {
            <div class="text-center text-muted-edurag py-5">
                <p class="mb-3">Chưa có môn học nào.</p>
                <a asp-page="/Courses/Create" class="btn btn-sm btn-edurag-warm">Thêm môn học</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table-edurag">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Tên môn</th>
                            <th>Mô tả</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model.Courses)
                        {
                            <tr>
                                <td class="fw-semibold">@course.Code</td>
                                <td>@course.Name</td>
                                <td class="small text-muted-edurag">@(string.IsNullOrWhiteSpace(course.Description) ? "—" : course.Description)</td>
                                <td>
                                    <span class="@(course.Status ? "status-badge-indexed" : "status-badge-failed")">
                                        @(course.Status ? "Hoạt động" : "Ngừng")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <span class="d-inline-flex gap-1">
                                        <a asp-page="/Courses/Edit" asp-route-id="@course.CourseId" class="btn btn-sm btn-edurag-ghost">Sửa</a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@course.CourseId" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
