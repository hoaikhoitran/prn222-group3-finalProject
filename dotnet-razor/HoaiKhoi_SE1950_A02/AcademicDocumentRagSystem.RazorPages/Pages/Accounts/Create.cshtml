@page
@using AcademicDocumentRagSystem.Services.DTOs.Accounts
@model AcademicDocumentRagSystem.RazorPages.Pages.Accounts.CreateModel
@{
    ViewData["Title"] = "Thêm tài khoản";
    Layout = "_LayoutDashboard";
}

<div class="edurag-page">
    <div class="mb-4">
        <a asp-page="/Accounts/Index" class="btn btn-sm btn-edurag-ghost mb-3 d-inline-flex align-items-center gap-1">
            @{ ViewData["Icon"] = "arrow-left"; ViewData["IconSize"] = "14"; }
            @await Html.PartialAsync("_Icons")
            Quay lại
        </a>
        <h1 class="font-display fs-2 fw-bold mb-1">Thêm tài khoản</h1>
        <p class="text-muted-edurag mb-0">Tạo tài khoản sinh viên hoặc giảng viên. Giảng viên có thể được gán nhiều môn ngay khi tạo, hoặc gán sau.</p>
    </div>

    <div class="card edurag-card" style="max-width:720px;">
        <div class="card-body p-4">
        <form method="post" class="vstack gap-3" id="createAccountForm" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div>
                <label asp-for="Input.Email" class="form-label fw-semibold"></label>
                <input asp-for="Input.Email" class="form-control" autocomplete="off" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Input.Password" class="form-label fw-semibold"></label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Input.FullName" class="form-label fw-semibold"></label>
                <input asp-for="Input.FullName" class="form-control" placeholder="Nguyễn Văn A" />
                <span asp-validation-for="Input.FullName" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Input.Role" class="form-label fw-semibold"></label>
                <select asp-for="Input.Role" class="form-select" id="accountRole">
                    <option value="@CreateAccountDto.StudentRole">Student</option>
                    <option value="@CreateAccountDto.TeacherRole">Teacher</option>
                </select>
                <span asp-validation-for="Input.Role" class="text-danger small"></span>
            </div>

            <div id="courseField">
                <label class="form-label fw-semibold">Môn học phụ trách</label>
                @if (!Model.UnassignedCourses.Any())
                {
                    <div class="form-text text-muted-edurag">
                        Hiện không còn môn học nào chưa có giảng viên. Có thể tạo tài khoản trước rồi gán môn sau
                        (hoặc dùng "Chuyển giảng viên" ở trang Môn học).
                    </div>
                }
                else
                {
                    <div class="vstack gap-1 border rounded p-2" style="max-height:200px;overflow-y:auto;" id="courseCheckboxList">
                        @foreach (var course in Model.UnassignedCourses)
                        {
                            <label class="form-check d-flex align-items-center gap-2 m-0">
                                <input type="checkbox" name="Input.CourseIds" value="@course.CourseId" class="form-check-input m-0 course-checkbox"
                                       checked="@Model.Input.CourseIds.Contains(course.CourseId)" />
                                <span class="small">@course.Code — @course.Name</span>
                            </label>
                        }
                    </div>
                    <div class="form-text text-muted-edurag" id="courseHelpTeacher">
                        Tuỳ chọn — có thể chọn nhiều môn. Chỉ hiện các môn chưa có giảng viên; giảng viên có thể được gán thêm môn bất kỳ lúc nào sau khi tạo.
                    </div>
                }
                <div class="form-text text-muted-edurag d-none" id="courseHelpStudent">Student không được gán môn học.</div>
                <span asp-validation-for="Input.CourseIds" class="text-danger small"></span>
            </div>

            <div class="form-check">
                <input asp-for="Input.Status" class="form-check-input" />
                <label asp-for="Input.Status" class="form-check-label">Tài khoản hoạt động</label>
            </div>

            <div class="d-flex gap-2 pt-2">
                <button type="submit" class="btn btn-edurag-warm">Lưu</button>
                <a asp-page="/Accounts/Index" class="btn btn-edurag-outline">Huỷ</a>
            </div>
        </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const roleSelect = document.getElementById('accountRole');
            const courseList = document.getElementById('courseCheckboxList');
            const courseHelpTeacher = document.getElementById('courseHelpTeacher');
            const courseHelpStudent = document.getElementById('courseHelpStudent');
            const teacherRole = '@CreateAccountDto.TeacherRole';

            function syncCourseField() {
                const isTeacher = roleSelect.value === teacherRole;
                document.querySelectorAll('.course-checkbox').forEach(function (checkbox) {
                    checkbox.disabled = !isTeacher;
                    if (!isTeacher) { checkbox.checked = false; }
                });
                if (courseList) { courseList.classList.toggle('opacity-50', !isTeacher); }
                if (courseHelpTeacher) { courseHelpTeacher.classList.toggle('d-none', !isTeacher); }
                courseHelpStudent.classList.toggle('d-none', isTeacher);
            }

            roleSelect.addEventListener('change', syncCourseField);
            syncCourseField();
        })();
    </script>
}
