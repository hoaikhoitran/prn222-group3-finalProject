@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Accounts.IndexModel
@{
    ViewData["Title"] = "Người dùng";
    Layout = "_LayoutDashboard";
}

@{
    var accounts = Model.Accounts ?? new List<AcademicDocumentRagSystem.Services.DTOs.Accounts.AccountListItemDto>();
    var totalAccounts = accounts.Count;
    var teacherCount = accounts.Count(a => a.RoleName == "Teacher");
    var studentCount = accounts.Count(a => a.RoleName == "Student");
    var activeCount = accounts.Count(a => a.Status);
}
<div class="edurag-page">
    <div class="page-hero">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
            <div>
                <span class="section-chip mb-2">
                    @{ ViewData["Icon"] = "users"; ViewData["IconSize"] = "13"; }
                    @await Html.PartialAsync("_Icons")
                    Admin · Người dùng
                </span>
                <h1 class="font-display fs-2 fw-bold mb-1 mt-2">Quản lý tài khoản</h1>
                <p class="text-muted-edurag mb-0">Tạo, cập nhật, lọc và quản lý tài khoản sinh viên, giảng viên</p>
            </div>
            <a asp-page="/Accounts/Create" class="btn btn-edurag-warm d-inline-flex align-items-center gap-1">
                @{ ViewData["Icon"] = "plus"; ViewData["IconSize"] = "14"; }
                @await Html.PartialAsync("_Icons")
                Thêm tài khoản
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card d-flex align-items-center gap-3">
                <span class="stat-card__icon stat-card__icon--warm">
                    @{ ViewData["Icon"] = "users"; ViewData["IconSize"] = "20"; }
                    @await Html.PartialAsync("_Icons")
                </span>
                <div>
                    <div class="stat-card__value">@totalAccounts</div>
                    <div class="stat-card__label">Tổng tài khoản</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card d-flex align-items-center gap-3">
                <span class="stat-card__icon stat-card__icon--slate">
                    @{ ViewData["Icon"] = "graduation"; ViewData["IconSize"] = "20"; }
                    @await Html.PartialAsync("_Icons")
                </span>
                <div>
                    <div class="stat-card__value">@teacherCount</div>
                    <div class="stat-card__label">Giảng viên</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card d-flex align-items-center gap-3">
                <span class="stat-card__icon stat-card__icon--amber">
                    @{ ViewData["Icon"] = "book"; ViewData["IconSize"] = "20"; }
                    @await Html.PartialAsync("_Icons")
                </span>
                <div>
                    <div class="stat-card__value">@studentCount</div>
                    <div class="stat-card__label">Sinh viên</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card d-flex align-items-center gap-3">
                <span class="stat-card__icon stat-card__icon--green">
                    @{ ViewData["Icon"] = "check-circle"; ViewData["IconSize"] = "20"; }
                    @await Html.PartialAsync("_Icons")
                </span>
                <div>
                    <div class="stat-card__value">@activeCount</div>
                    <div class="stat-card__label">Đang hoạt động</div>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-3">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-3">@TempData["Success"]</div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning mb-3">@TempData["Warning"]</div>
    }

    <div class="card edurag-card mb-4">
        <div class="card-body">
        <form asp-page="/Accounts/Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-semibold" for="searchTerm">Tìm kiếm</label>
                <input id="searchTerm" name="SearchTerm" value="@Model.SearchTerm" class="form-control form-control-sm" placeholder="Email hoặc họ tên" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold" for="role">Vai trò</label>
                <select id="role" name="Role" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    @if (Model.Role == 1) { <option value="1" selected>Student</option> } else { <option value="1">Student</option> }
                    @if (Model.Role == 2) { <option value="2" selected>Teacher</option> } else { <option value="2">Teacher</option> }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold" for="status">Trạng thái</label>
                <select id="status" name="Status" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    @if (Model.Status == true) { <option value="true" selected>Hoạt động</option> } else { <option value="true">Hoạt động</option> }
                    @if (Model.Status == false) { <option value="false" selected>Đã khoá</option> } else { <option value="false">Đã khoá</option> }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-edurag-outline">Lọc</button>
                <a asp-page="/Accounts/Index" class="btn btn-sm btn-edurag-ghost">Đặt lại</a>
            </div>
        </form>
        </div>
    </div>

    <div class="card edurag-card overflow-hidden">
        <div class="card-header d-flex align-items-center justify-content-between" style="background:var(--edurag-sidebar);border-color:var(--edurag-border);">
            <span class="fw-semibold small">Danh sách tài khoản</span>
            <span class="text-muted-edurag small">@totalAccounts kết quả</span>
        </div>
        @if (Model.Accounts == null || !Model.Accounts.Any())
        {
            <div class="text-center text-muted-edurag py-5">
                <p class="mb-3">Không tìm thấy tài khoản.</p>
                <a asp-page="/Accounts/Create" class="btn btn-sm btn-edurag-warm">Thêm tài khoản</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table-edurag">
                    <thead>
                        <tr>
                            <th>Người dùng</th>
                            <th>Vai trò</th>
                            <th style="min-width:220px;">Môn phụ trách</th>
                            <th>Trạng thái</th>
                            <th style="min-width:230px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var account in Model.Accounts)
                        {
                            var badge = account.RoleName == "Student" ? "role-badge-student" : "role-badge-teacher";
                            var isTeacher = account.RoleName == "Teacher";
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="avatar-initial" style="width:36px;height:36px;font-size:14px;">@(account.FullName.Length > 0 ? account.FullName[0] : '?')</span>
                                        <div>
                                            <div class="fw-semibold">@account.FullName</div>
                                            <div class="small text-muted-edurag">@account.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="@badge">@account.RoleName</span></td>
                                <td class="small">
                                    @if (!isTeacher)
                                    {
                                        <span class="text-muted-edurag">—</span>
                                    }
                                    else if (account.AssignedCourseCount == 0)
                                    {
                                        <span class="status-badge-pending">Chưa phân công</span>
                                    }
                                    else
                                    {
                                        <div class="fw-semibold mb-1">Số môn phụ trách: @account.AssignedCourseCount</div>
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var course in account.AssignedCourses)
                                            {
                                                <span class="badge rounded-pill bg-light text-dark border d-inline-flex align-items-center gap-1 px-2 py-1" title="@course.Name">
                                                    @course.Code
                                                    <form method="post" asp-page-handler="UnassignCourse"
                                                          asp-route-courseId="@course.CourseId"
                                                          asp-route-SearchTerm="@Model.SearchTerm"
                                                          asp-route-Role="@Model.Role"
                                                          asp-route-Status="@Model.Status"
                                                          class="d-inline m-0"
                                                          onsubmit="return confirm('Bạn có chắc muốn bỏ giảng viên khỏi môn @course.Code?\nTài liệu không bị xóa nhưng giảng viên sẽ mất quyền quản lý môn này.');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-link p-0 border-0 text-danger" style="font-size:12px;line-height:1;text-decoration:none;" aria-label="Bỏ gán môn @course.Code" title="Bỏ gán môn @course.Code">×</button>
                                                    </form>
                                                </span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="@(account.Status ? "status-badge-indexed" : "status-badge-failed")">
                                        @(account.Status ? "Hoạt động" : "Đã khoá")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <span class="d-inline-flex gap-1 flex-wrap justify-content-end">
                                        @if (isTeacher && account.Status)
                                        {
                                            <details class="assign-courses-dropdown d-inline-block">
                                                <summary class="btn btn-sm btn-edurag-outline">Gán thêm môn học</summary>
                                                <div class="assign-courses-panel edurag-card p-3 text-start">
                                                    <div class="fw-semibold small mb-1">@account.FullName</div>
                                                    @if (account.AssignedCourseCount > 0)
                                                    {
                                                        <div class="small text-muted-edurag mb-2">
                                                            Đang phụ trách: @string.Join(", ", account.AssignedCourses.Select(c => c.Code))
                                                        </div>
                                                    }
                                                    @if (!Model.UnassignedCourses.Any())
                                                    {
                                                        <div class="small text-muted-edurag">Không còn môn học nào chưa có giảng viên. Muốn chuyển môn từ giảng viên khác, dùng "Chuyển giảng viên" ở trang Môn học.</div>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-page-handler="AssignCourses"
                                                              asp-route-teacherAccountId="@account.AccountId"
                                                              asp-route-SearchTerm="@Model.SearchTerm"
                                                              asp-route-Role="@Model.Role"
                                                              asp-route-Status="@Model.Status"
                                                              class="vstack gap-2">
                                                            @Html.AntiForgeryToken()
                                                            <div class="small text-muted-edurag">Chọn các môn chưa có giảng viên:</div>
                                                            <div class="vstack gap-1" style="max-height:180px;overflow-y:auto;">
                                                                @foreach (var course in Model.UnassignedCourses)
                                                                {
                                                                    <label class="form-check d-flex align-items-center gap-2 m-0">
                                                                        <input type="checkbox" name="courseIds" value="@course.CourseId" class="form-check-input m-0" />
                                                                        <span class="small">@course.Code — @course.Name</span>
                                                                    </label>
                                                                }
                                                            </div>
                                                            <button type="submit" class="btn btn-sm btn-edurag-warm">Gán các môn đã chọn</button>
                                                        </form>
                                                    }
                                                </div>
                                            </details>
                                        }
                                        <a asp-page="/Accounts/Edit" asp-route-id="@account.AccountId" class="btn btn-sm btn-edurag-ghost">Sửa</a>
                                        <form method="post" asp-page="/Accounts/Index" asp-page-handler="Delete" asp-route-id="@account.AccountId" class="d-inline"
                                              onsubmit="return confirm('Bạn có chắc muốn xóa tài khoản @account.Email?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .assign-courses-dropdown { position: relative; }

    .assign-courses-dropdown summary { list-style: none; cursor: pointer; }

        .assign-courses-dropdown summary::-webkit-details-marker { display: none; }

    .assign-courses-panel {
        position: absolute;
        right: 0;
        top: calc(100% + 6px);
        z-index: 30;
        min-width: 320px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, .14);
    }
</style>

<script>
    // Only one "Gán thêm môn" panel open at a time; close on outside click.
    (function () {
        document.addEventListener("click", function (event) {
            document.querySelectorAll("details.assign-courses-dropdown[open]").forEach(function (details) {
                if (!details.contains(event.target)) {
                    details.removeAttribute("open");
                }
            });
        });
        document.addEventListener("toggle", function (event) {
            var target = event.target;
            if (!(target instanceof HTMLDetailsElement) || !target.classList.contains("assign-courses-dropdown") || !target.open) {
                return;
            }
            document.querySelectorAll("details.assign-courses-dropdown[open]").forEach(function (details) {
                if (details !== target) { details.removeAttribute("open"); }
            });
        }, true);
    })();
</script>
