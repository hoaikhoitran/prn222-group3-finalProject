<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduRAG</title>
    <link rel="stylesheet" href="~/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tabler-vendors.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/edurag-theme.css" asp-append-version="true" />
</head>
<body class="edurag-body">
    <div class="page">
        <div class="dashboard-shell">
            @await Html.PartialAsync("_RoleSidebar")
            <div class="page-wrapper dashboard-main">
                <div class="page-body">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/tabler.min.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
