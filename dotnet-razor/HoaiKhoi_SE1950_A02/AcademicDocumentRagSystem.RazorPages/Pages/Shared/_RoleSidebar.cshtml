@using AcademicDocumentRagSystem.RazorPages.ViewModels
@{
    var sessionRole = Context.Session.GetString("RoleName");
    var accent = ViewBag.SidebarAccent as string ?? sessionRole switch
    {
        "Admin" => "Admin",
        "Teacher" => "Giảng viên",
        "Student" => "Sinh viên",
        _ => ""
    };
    var navItems = ViewBag.NavItems as List<SidebarNavItem>;
    if (navItems == null || navItems.Count == 0)
    {
        navItems = sessionRole switch
        {
            "Admin" => SidebarNav.Admin,
            "Teacher" => SidebarNav.Teacher,
            _ => new List<SidebarNavItem>()
        };
    }
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var fullName = Context.Session.GetString("FullName") ?? "Người dùng";
    var roleName = sessionRole ?? ViewBag.SidebarRole as string ?? "";
    var initial = !string.IsNullOrEmpty(fullName) ? fullName[0].ToString().ToUpper() : "U";
}
<aside class="role-sidebar" data-edurag-sidebar aria-label="Điều hướng">
    <div class="role-sidebar__brand">
        <div class="sidebar-brand-row">
            <div class="sidebar-brand-slot">
                <a asp-page="/Home/Index" class="sidebar-brand-link d-flex align-items-center gap-2 text-decoration-none text-dark min-width-0">
                    <span class="edurag-logo-mark bg-gradient-warm text-white d-inline-flex align-items-center justify-content-center flex-shrink-0">
                        @{ ViewData["Icon"] = "sparkles"; ViewData["IconSize"] = "20"; }
                        @await Html.PartialAsync("_Icons")
                    </span>
                    <span class="sidebar-label">
                        <span class="font-display fw-bold lh-1 d-block">EduRAG</span>
                        <span class="text-uppercase text-muted-edurag" style="font-size:11px;letter-spacing:.08em;">@accent</span>
                    </span>
                </a>
                <button type="button" class="sidebar-toggle" data-sidebar-toggle title="Thu gọn / mở rộng thanh bên" aria-label="Thu gọn / mở rộng thanh bên" aria-expanded="true">
                    @{ ViewData["Icon"] = "chevron-left"; ViewData["IconSize"] = "16"; }
                    @await Html.PartialAsync("_Icons")
                </button>
            </div>
        </div>
    </div>
    <nav class="role-sidebar__nav">
        @foreach (var item in navItems)
        {
            var pageBase = item.Page.TrimEnd('/');
            var itemSection = pageBase.Contains('/')
                ? pageBase[..pageBase.LastIndexOf('/')]
                : pageBase;
            var inSameSection = currentPage.StartsWith(itemSection + "/", StringComparison.OrdinalIgnoreCase);
            var isIndexFamily = item.Page.Contains("/Index", StringComparison.OrdinalIgnoreCase)
                && inSameSection
                && (currentPage.Contains("/Create", StringComparison.OrdinalIgnoreCase)
                    || currentPage.Contains("/Edit", StringComparison.OrdinalIgnoreCase));
            var isAllFamily = item.Page.Contains("/All", StringComparison.OrdinalIgnoreCase)
                && inSameSection
                && (currentPage.Contains("/DocumentDetails", StringComparison.OrdinalIgnoreCase)
                    || currentPage.Contains("/Documents/Details", StringComparison.OrdinalIgnoreCase));
            var isActive = string.Equals(currentPage, item.Page, StringComparison.OrdinalIgnoreCase)
                || currentPage.StartsWith(pageBase + "/", StringComparison.OrdinalIgnoreCase)
                || isIndexFamily || isAllFamily;
            <a asp-page="@item.Page"
               class="role-sidebar__link @(isActive ? "active" : "")"
               title="@item.Label">
                @{ ViewData["Icon"] = item.Icon; ViewData["IconSize"] = "16"; }
                @await Html.PartialAsync("_Icons")
                <span class="sidebar-label">@item.Label</span>
            </a>
        }
    </nav>
    <div class="role-sidebar__footer">
        <div class="sidebar-user align-items-center rounded-3" style="background:rgba(28,25,23,.04);">
            <div class="sidebar-user-slot">
                <div class="avatar-initial" title="@fullName">@initial</div>
            </div>
            <div class="sidebar-label min-width-0">
                <div class="small fw-semibold text-truncate">@fullName</div>
                <div class="text-muted-edurag" style="font-size:12px;">@roleName</div>
            </div>
            <a asp-page="/Auth/Logout" class="sidebar-logout" data-logout-confirm title="Đăng xuất" aria-label="Đăng xuất">
                @{ ViewData["Icon"] = "logout"; ViewData["IconSize"] = "16"; }
                @await Html.PartialAsync("_Icons")
            </a>
        </div>
    </div>
</aside>
