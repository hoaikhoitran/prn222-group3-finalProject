@using AcademicDocumentRagSystem.Services.DTOs.Chat
@{
    var sessions = ViewBag.RecentSessions as List<ChatSessionDto> ?? new List<ChatSessionDto>();
    var selectedSessionId = ViewBag.SelectedSessionId as int?;
    var fullName = Context.Session.GetString("FullName") ?? "Sinh viên";
    var initial = !string.IsNullOrEmpty(fullName) ? fullName[0].ToString().ToUpper() : "S";
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduRAG</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tabler-vendors.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/edurag-theme.css" asp-append-version="true" />
    <script>document.documentElement.classList.add('student-reveal-ready');</script>
    <script>
        (function () {
            try {
                if (localStorage.getItem("edurag.sidebarCollapsed") === "1") {
                    document.documentElement.classList.add("sidebar-collapsed");
                }
            } catch (e) { }
        })();
    </script>
</head>
<body class="edurag-body student-area">
    <div class="page">
        <div class="dashboard-shell">
            <aside class="student-sidebar" data-edurag-sidebar aria-label="Điều hướng sinh viên">
                <div class="student-sidebar__head">
                    <div class="sidebar-brand-row mb-3">
                        <div class="sidebar-brand-slot">
                            <a asp-page="/Home/Index" class="sidebar-brand-link text-decoration-none text-dark min-width-0">
                                <span class="edurag-logo-mark bg-gradient-warm text-white d-inline-flex align-items-center justify-content-center flex-shrink-0">
                                    @{ ViewData["Icon"] = "book"; ViewData["IconSize"] = "20"; }
                                    @await Html.PartialAsync("_Icons")
                                </span>
                                <span class="sidebar-label">
                                    <span class="font-display fw-bold lh-1 d-block">EduRAG</span>
                                    <span class="text-uppercase text-muted-edurag" style="font-size:11px;letter-spacing:.08em;">Sinh viên</span>
                                </span>
                            </a>
                            <button type="button" class="sidebar-toggle" data-sidebar-toggle title="Thu gọn / mở rộng thanh bên" aria-label="Thu gọn / mở rộng thanh bên" aria-expanded="true">
                                @{ ViewData["Icon"] = "chevron-left"; ViewData["IconSize"] = "16"; }
                                @await Html.PartialAsync("_Icons")
                            </button>
                        </div>
                    </div>
                    <a asp-page="/Student/Chat" class="btn btn-edurag-warm btn-sm w-100" title="Cuộc trò chuyện mới">
                        @{ ViewData["Icon"] = "pen"; ViewData["IconSize"] = "14"; }
                        @await Html.PartialAsync("_Icons")
                        <span class="sidebar-label">Cuộc trò chuyện mới</span>
                    </a>
                </div>
                <div class="student-sidebar__body">
                    <a asp-page="/Student/Library"
                       class="role-sidebar__link @(currentPage.Contains("/Student/Library") || currentPage.Contains("/Student/Document") ? "active" : "")"
                       title="Thư viện">
                        @{ ViewData["Icon"] = "book"; ViewData["IconSize"] = "16"; }
                        @await Html.PartialAsync("_Icons")
                        <span class="sidebar-label">Thư viện</span>
                    </a>
                    @if (sessions.Any())
                    {
                        <div class="sidebar-label small fw-semibold text-muted-edurag text-uppercase px-2 mt-3 mb-1" style="font-size:11px;letter-spacing:.06em;">Gần đây</div>
                        @foreach (var s in sessions.Take(12))
                        {
                            <a asp-page="/Student/Chat" asp-route-documentId="@s.DocumentId" asp-route-sessionId="@s.ChatSessionId"
                               class="session-item @(selectedSessionId == s.ChatSessionId ? "active" : "")"
                               title="@s.Title">
                                <span class="d-block text-truncate fw-medium sidebar-label">@s.Title</span>
                                <span class="d-block text-muted-edurag sidebar-label" style="font-size:11px;">@s.CourseCode · @((s.UpdatedAt ?? s.CreatedAt).ToLocalTime().ToString("dd/MM"))</span>
                                <span class="session-item__dot" aria-hidden="true"></span>
                            </a>
                        }
                    }
                </div>
                <div class="student-sidebar__footer">
                    <div class="sidebar-user align-items-center rounded-3" style="background:rgba(28,25,23,.04);">
                        <div class="sidebar-user-slot">
                            <div class="avatar-initial" title="@fullName">@initial</div>
                        </div>
                        <div class="sidebar-label min-width-0">
                            <div class="small fw-semibold text-truncate">@fullName</div>
                            <div class="text-muted-edurag" style="font-size:11px;">Student</div>
                        </div>
                        <a asp-page="/Auth/Logout" class="sidebar-logout" data-logout-confirm title="Đăng xuất" aria-label="Đăng xuất">
                            @{ ViewData["Icon"] = "logout"; ViewData["IconSize"] = "15"; }
                            @await Html.PartialAsync("_Icons")
                        </a>
                    </div>
                </div>
            </aside>
            <div class="page-wrapper dashboard-main">
                <div class="page-body">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>
    @await Html.PartialAsync("_ConfirmDialog")
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/tabler.min.js" asp-append-version="true"></script>
    <script src="~/js/sidebar-toggle.js" asp-append-version="true"></script>
    <script src="~/js/confirm-dialog.js" asp-append-version="true"></script>
    <script src="~/js/student-reveal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
