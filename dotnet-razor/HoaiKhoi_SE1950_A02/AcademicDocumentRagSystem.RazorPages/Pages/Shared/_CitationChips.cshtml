@using AcademicDocumentRagSystem.Services.DTOs.Rag
@model IEnumerable<RagSourceDto>
@{
    // These are the sources the AI actually cited in its answer (the RAG
    // service filters retrieval down to used citations before they reach
    // us). Old history without citation IDs falls back to chunk labels.
    var sources = (Model ?? Enumerable.Empty<RagSourceDto>())
        .Where(s => s != null)
        .GroupBy(s =>
        {
            if (!string.IsNullOrWhiteSpace(s.CitationId))
            {
                return "c:" + s.CitationId.Trim().ToUpperInvariant();
            }

            var text = (s.Text ?? string.Empty).Trim();
            if (!string.IsNullOrEmpty(text))
            {
                return "t:" + text;
            }

            return $"f:{s.FileName}|p:{s.PageNumber}|c:{s.ChunkIndex}";
        })
        .Select(g => g.First())
        .ToList();
}
@if (sources.Any())
{
    <div class="small text-muted-edurag mt-2" style="font-size:11px;">Nguồn được dùng trong câu trả lời</div>
    <div class="citation-row d-flex flex-wrap gap-1 mt-1">
        @foreach (var cit in sources)
        {
            var fileLabel = string.IsNullOrWhiteSpace(cit.FileName) ? "Tài liệu" : cit.FileName;
            var chunkLabel = $"chunk {cit.ChunkIndex + 1}";
            var locLabel = cit.PageNumber.HasValue
                ? $"trang {cit.PageNumber} · {chunkLabel}"
                : chunkLabel;
            var metaLabel = $"{fileLabel} · {locLabel}";
            var preview = string.IsNullOrWhiteSpace(cit.Text)
                ? "Không có nội dung trích dẫn cho nguồn này."
                : cit.Text.Trim();

            var hasUploaderName = !string.IsNullOrWhiteSpace(cit.UploadedByFullName);
            var hasUploaderEmail = !string.IsNullOrWhiteSpace(cit.UploadedByEmail);
            <div class="citation-chip-wrap">
                <button type="button"
                        class="citation-chip"
                        aria-expanded="false"
                        title="@metaLabel — bấm hoặc di chuột để xem nội dung trích dẫn">
                    @{ ViewData["Icon"] = "quote"; ViewData["IconSize"] = "12"; }
                    @await Html.PartialAsync("_Icons")
                    <span>@fileLabel</span>
                    <span class="citation-chip__loc">· @locLabel</span>
                </button>
                <div class="citation-popover" hidden>
                    <div class="citation-popover__head">
                        <span class="fw-semibold">@metaLabel</span>
                        <button type="button" class="citation-popover__close" aria-label="Đóng">&times;</button>
                    </div>
                    <div class="citation-popover__meta small text-muted-edurag px-3 pt-2" style="line-height:1.6;">
                        <div><span class="fw-semibold">Tài liệu:</span> @fileLabel</div>
                        @if (!string.IsNullOrWhiteSpace(cit.Chapter))
                        {
                            <div><span class="fw-semibold">Chương:</span> @cit.Chapter</div>
                        }
                        else
                        {
                            <div><span class="fw-semibold">Chương:</span> Không có thông tin</div>
                        }
                        @if (cit.PageNumber.HasValue)
                        {
                            <div><span class="fw-semibold">Trang:</span> @cit.PageNumber</div>
                        }
                        <div><span class="fw-semibold">Chunk số:</span> @(cit.ChunkIndex + 1)</div>
                        @if (hasUploaderName && hasUploaderEmail)
                        {
                            <div><span class="fw-semibold">Người đăng tải:</span> @cit.UploadedByFullName</div>
                            <div><span class="fw-semibold">Email:</span> @cit.UploadedByEmail</div>
                        }
                        else if (hasUploaderName)
                        {
                            <div><span class="fw-semibold">Người đăng tải:</span> @cit.UploadedByFullName</div>
                        }
                        else if (hasUploaderEmail)
                        {
                            <div><span class="fw-semibold">Người đăng tải:</span> @cit.UploadedByEmail</div>
                        }
                        else
                        {
                            <div><span class="fw-semibold">Người đăng tải:</span> Không có thông tin</div>
                        }
                    </div>
                    <div class="citation-popover__label small fw-semibold px-3 pt-2 text-muted-edurag">Nội dung được sử dụng:</div>
                    <div class="citation-popover__text">@preview</div>
                </div>
            </div>
        }
    </div>
}
