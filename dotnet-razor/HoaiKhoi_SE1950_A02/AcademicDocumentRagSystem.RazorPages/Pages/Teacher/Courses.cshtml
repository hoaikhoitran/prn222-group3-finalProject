@page
@model AcademicDocumentRagSystem.RazorPages.Pages.Teacher.CoursesModel
@using AcademicDocumentRagSystem.RazorPages.ViewModels
@{
    ViewData["Title"] = "Môn học";
    Layout = "_LayoutDashboard";
    var cards = Model.Cards;
}
<div class="edurag-page">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <span class="section-chip mb-2">
                @{ ViewData["Icon"] = "graduation"; ViewData["IconSize"] = "13"; }
                @await Html.PartialAsync("_Icons")
                Giảng viên · Môn học
            </span>
            <h1 class="font-display fs-2 fw-bold mb-1 mt-2">Môn học của bạn</h1>
            <p class="text-muted-edurag mb-0">
                @cards.Count môn được phân công · @cards.Sum(c => c.DocumentCount) tài liệu · @cards.Sum(c => c.TotalChunks).ToString("N0") chunks
                <span id="live-indicator" class="live-indicator ms-1">live</span>
            </p>
        </div>
    </div>
    <div id="course-list" data-refresh-url="@Url.Page("/Teacher/Courses", "Table")">
        @await Html.PartialAsync("_CourseCards", cards)
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js" crossorigin="anonymous"></script>
    <script src="~/js/course-realtime.js" asp-append-version="true"></script>
}
