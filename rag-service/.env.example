# =============================================================================
# Retrieval-Augmented-Generation-PRN222 - example environment file
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values for your local environment.
# DO NOT commit your real ".env" file. Only this example file should be shared.
# =============================================================================

# --- General application settings -------------------------------------------
APP_NAME=Retrieval-Augmented-Generation-PRN222
APP_ENV=development

# If empty: API key is NOT required (good for local development).
# If you set a value, every request must send header:  X-API-Key: <value>
API_KEY=

# --- Vector database (ChromaDB) ---------------------------------------------
# Directory where ChromaDB persists its data (relative path is fine).
CHROMA_PERSIST_DIR=./chroma_db
# Name of the ChromaDB collection that stores all chunks.
CHROMA_COLLECTION_NAME=prn222_documents

# --- Embedding model --------------------------------------------------------
# Main embedding model. BAAI/bge-m3 is multilingual and works well for
# Vietnamese + English academic content.
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# --- Chunking configuration -------------------------------------------------
# chunk_size:    approximate length (in characters) of each chunk.
# chunk_overlap: characters shared between two neighboring chunks
#                so that no sentence is cut off and context is preserved.
# DEFAULT_TOP_K: number of most relevant chunks to retrieve per question.
CHUNK_SIZE=1500
CHUNK_OVERLAP=250
DEFAULT_TOP_K=5

# --- Retrieval relevance threshold ------------------------------------------
# top_k alone is not enough: ChromaDB will always return the K *nearest*
# chunks, even when those chunks are still very far from the question.
# RAG_MAX_DISTANCE filters them out by cosine distance:
#   * smaller distance == more similar
#   * keep chunks where distance <= RAG_MAX_DISTANCE, drop the rest
# RAG_MIN_RELEVANT_CHUNKS is the minimum number of chunks that must pass
# the threshold for the service to attempt an answer. If fewer pass, the
# service returns the standard "Không đủ thông tin..." fallback instead.
#
# 0.45 is a reasonable starting point for BAAI/bge-m3 with cosine distance;
# tune it per corpus (lower => stricter, higher => more permissive).
RAG_MAX_DISTANCE=0.45
RAG_MIN_RELEVANT_CHUNKS=1

# --- LLM (Generation) configuration -----------------------------------------
# MOCK_LLM=true makes the service work WITHOUT any paid LLM API key.
# When true: the LLM step returns a simple, deterministic answer built from
# the retrieved document context only (no hallucination).
# Set MOCK_LLM=false to call a real provider (e.g. Gemini) for generation.
MOCK_LLM=false

# Which provider to use when MOCK_LLM=false
# (mock | gemini | openai | ollama | ...). "mock" and "gemini" are implemented.
LLM_PROVIDER=gemini

# Gemini API key. Get one from https://aistudio.google.com/apikey
# DO NOT commit a real key — keep it only in your local .env (which is gitignored).
LLM_API_KEY=your_gemini_api_key_here

# Gemini model used for the GENERATION step.
# Prefer *-latest aliases — fixed ids like gemini-2.5-flash-lite can 404 for new API keys.
LLM_MODEL_NAME=gemini-flash-lite-latest

# --- Server -----------------------------------------------------------------
PORT=8000
